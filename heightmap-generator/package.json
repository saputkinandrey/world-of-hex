{
  "name": "world-of-hex-heightmap-generator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "wohex-heightmap": "src/cli.mjs"
  },
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "start": "next start -p 3003",
    "generate": "node src/cli.mjs",
    "generate:sample": "node src/cli.mjs --config config/sample.ini --output out --count 1 --size 257 --bit-depth 16",
    "test": "node tests/smoke-test.mjs",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.8.3"
  }
}
