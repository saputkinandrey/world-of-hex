{
  "sheet": "GOODS",
  "calculationRules": {
    "effectiveStatus": "effectiveStatus is the extracted price status used for multiplier lookup. For materialized goods, effectiveStatus is stored on each materials item. statusAdjustment is retained when present as the source modifier; semantic categories are stored separately in categories.",
    "statusMultiplier": "Look up effectiveStatus in statuses.",
    "pricePerPound": "basePrice * statusMultiplier. For item-priced rows with unitQuantity, use basePrice * statusMultiplier / unitQuantity.",
    "quart": "pricePerPound * 2",
    "gallon": "quart * 4",
    "ton": "pricePerPound * 2000",
    "ounce": "pricePerPound / 100 * 6",
    "shot": "ounce * 10 / 6",
    "glass": "shot * 5",
    "crate": "pricePerPound * 300",
    "barrelOrSack": "pricePerPound * 150",
    "basket": "barrelOrSack / 10"
  },
